---
import BackToTopButton from "../components/BackToTopButton.astro";
import FooterComponent from "../components/layout/FooterComponent.astro";
import HeaderComponent from "../components/layout/HeaderComponent.astro";
import BaseLayout from "./BaseLayout.astro";



const { frontmatter  } = Astro.props;
---

<BaseLayout PageTitle = { frontmatter.title }>

    <HeaderComponent />

    <main class="container mx-auto px-6 py-8">
        <h1 class="text-2xl font-bold">{frontmatter.title}</h1>
        <section class="flex flex-wrap gap-5 items-center mt-2 mb-6">
            <div class="flex items-center gap-1 text-xs border rounded-md shadow-sm px-2 py-0.5 text-neutral-500 dark:border-neutral-800 dark:text-neutral-600">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-3.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
                <span>{frontmatter.date.toString().slice(0,10)}</span>
            </div>
        </section>
        <article class="post-content text-base ">
            <slot />
        </article>
    </main>

    <FooterComponent />
    
    <BackToTopButton />

</BaseLayout>


<style is:global>
    .post-content p{
        display: block;
        margin-block-start: 1em;
        margin-block-end: 1em;
    }

    .post-content img {
        width: auto;
        max-width: 100%;
    }

    @tailwind base;
    @tailwind components;
    @tailwind utilities;

    @layer base{
        .post-content h1, .post-content h2, .post-content h3, .post-content h4, .post-content h5, .post-content h6 {
            @apply relative mb-4 mt-6 hover:before:content-['#'] before:absolute before:-inset-2 before:place-content-center before:text-neutral-200 before:font-light dark:before:text-neutral-700;
        }
        .post-content h1, .post-content h2, .post-content h3, .post-content h4 { 
            @apply font-bold;
         }
         .post-content h1 {
            @apply text-2xl before:-inset-4;
         }
         .post-content h2 {
            @apply text-xl before:-inset-3.5;
         }
         .post-content h3 {
            @apply text-lg before:-inset-3.5;
         }
         .post-content h4 {
            @apply text-base before:-inset-3;
         }
         .post-content h5 {
            @apply text-sm before:-inset-2.5;
         }
         .post-content h6 {
            @apply text-xs before:-inset-2;
         }
    }

</style>